# ─────────────────────────────────────────────
# Supabase (PostgreSQL)
# ─────────────────────────────────────────────
# DATABASE_URL — usa la conexión directa (puerto 5432)
# Ve a: Supabase > Project Settings > Database > Connection string > URI
# Selecciona "Mode: Session" o copia la URI directa con puerto 5432
DATABASE_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres"

# ─────────────────────────────────────────────
# App
# ─────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ─────────────────────────────────────────────
# Cómo obtener las credenciales de Supabase:
# 1. Crea un proyecto en https://supabase.com
# 2. Ve a Project Settings > Database
# 3. Copia la "Connection string" (URI)
# 4. Reemplaza [PASSWORD] y [PROJECT_REF] con tus valores
# 5. Usa el puerto 5432 (conexión directa, no el pooler 6543)
# ─────────────────────────────────────────────
